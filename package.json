{
	"name": "core",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "eslint .",
		"deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"deploy:development": "opennextjs-cloudflare build && opennextjs-cloudflare deploy --env development",
		"upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
		"upload:development": "opennextjs-cloudflare build && opennextjs-cloudflare upload --env development",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"cf-typegen:development": "wrangler types --env development --env-interface CloudflareEnv ./cloudflare-env.d.ts"
	},
	"dependencies": {
		"@opennextjs/cloudflare": "^1.19.4",
		"framer-motion": "^12.38.0",
		"next": "^16.2.4",
		"next-sanity": "^12.3.2",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"sanity": "^5.23.0",
		"styled-components": "^6.3.12"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19.1.5",
		"@types/react-dom": "^19.1.5",
		"eslint": "^9",
		"eslint-config-next": "15.4.6",
		"node-addon-api": "^8.5.0",
		"node-gyp": "^12.2.0",
		"tailwindcss": "^4",
		"typescript": "^5.7.4",
		"wrangler": "^4.80.0"
	},
	"overrides": {
		"js-yaml": "^3.14.2",
		"postcss": "^8.5.10",
		"uuid": "^14.0.0"
	}
}
